# Backend local dev environment
# Copy to backend/.env and fill in your values

DATABASE_URL=postgresql+asyncpg://wuwa_toolkit_user:your_password@localhost:5432/wuwa_toolkit_db

# OCR providers (EasyOCR works without any key)
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

UPLOAD_DIR=/home/your_username/Projects/Echoes_Optimizer/backend/uploads
MAX_UPLOAD_SIZE_MB=20
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000
