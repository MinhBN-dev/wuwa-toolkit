# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL credentials for the Docker Compose postgres service
POSTGRES_USER=wuwa_toolkit_user
POSTGRES_PASSWORD=change_me_please

# ── OCR (at least one key recommended) ────────────────────────────────────────
# EasyOCR works locally without any key.
# Cloud providers are used as fallback in this order: Gemini → OpenAI → Anthropic.
#
# Google AI Studio (free, 1000 req/day): https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Optional cloud fallbacks
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# Port to expose the app on (default: 80)
PORT=80

# Comma-separated list of allowed origins for CORS
# Add your LAN IP or domain if you want to access from other devices
ALLOWED_ORIGINS=http://localhost
